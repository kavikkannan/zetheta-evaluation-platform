# Database
POSTGRES_DB=zetheta
POSTGRES_USER=zetheta
POSTGRES_PASSWORD=zetheta
DATABASE_URL=postgresql://zetheta:zetheta@postgres:5432/zetheta

# Redis
REDIS_URL=redis://redis:6379

# JWT / Auth
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key.pem
JWT_ISSUER=https://zetheta.com
JWT_AUDIENCE=assessment-engine

# Service Ports
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
WEBSOCKET_SERVER_PORT=3003
CANDIDATE_PORTAL_PORT=4001
ASSESSMENT_ENGINE_PORT=4002
EMPLOYER_DASHBOARD_PORT=4003

# Frontend Base URLs
CANDIDATE_PORTAL_URL=http://localhost:4001
ASSESSMENT_ENGINE_URL=http://localhost:4002
EMPLOYER_DASHBOARD_URL=http://localhost:4003

